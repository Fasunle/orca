{
  "name": "@fasunle/orca",
  "version": "0.1.0",
  "description": "Orca - Task orchestrator with intelligent caching for monorepos using Bun",
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "bin": {
    "orca": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fasunle/orca.git"
  },
  "homepage": "https://github.com/fasunle/orca#readme",
  "bugs": {
    "url": "https://github.com/fasunle/orca/issues"
  },
  "keywords": [
    "bun",
    "monorepo",
    "cache",
    "orca",
    "performance",
    "build-cache",
    "task-orchestration",
    "task-runner",
    "turbo",
    "turbo alternative"
  ],
  "author": "Kehinde Fasunle<kfasunle@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target node",
    "dev": "bun run ./src/cli.ts",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage && bun run scripts/generate-coverage-summary.ts",
    "prepublishOnly": "bun run build && bun run test:run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish-packages": "npm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "latest",
    "bun-types": "latest",
    "prettier": "^3.8.4",
    "vitest": "latest"
  },
  "peerDependencies": {
    "rimraf": "^6.1.3",
    "chalk": "^5.6.2",
    "commander": "^15.0.0"
  }
}
